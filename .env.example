# TMDB API Key (required for searching movies/TV shows)
# Get your free API key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Android TV Configuration
# The IP address of your Android TV (required)
ANDROID_TV_HOST=192.168.1.100

# Current ADB connection port shown by Wireless Debugging (not the pairing port)
# Legacy network debugging often uses 5555.
ANDROID_TV_PORT=37139

# Optional path to the native ADB executable when it is not available on PATH
# ADB_PATH=/absolute/path/to/adb

# Stremio Authentication Key (optional - for library access)
# To get your auth key:
# 1. Go to https://web.stremio.com and login
# 2. Open browser console (F12)
# 3. Run: JSON.parse(localStorage.getItem("profile")).auth.key
# 4. Copy the value here
STREMIO_AUTH_KEY=
